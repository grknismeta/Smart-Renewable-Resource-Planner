# SRRP — Environment template
# `.env` olarak kopyalayın ve değerleri doldurun. `.gitignore`'da `.env`
# ignore'da — secret'lar repo'ya gitmez.
#
# Kullanım:
#   1. cp .env.example .env
#   2. Aşağıdaki değişkenleri kendi değerlerinizle doldurun
#   3. docker-compose up -d --build backend
# (compose otomatik olarak .env'i `env_file:` üzerinden backend'e iletir.)

# ─── Database (compose'dan default'lar kullanılır, override için doldurun) ──
# DATABASE_URL=postgresql://srrp_admin:srrp_secure_2026@db:5432/srrp_db

# ─── Redis (compose'dan default — backend → redis container) ────────────────
# REDIS_URL=redis://redis:6379/0

# ─── JWT / Auth (compose'da hard-coded, override için açın) ─────────────────
# SECRET_KEY=your-256-bit-secret-here
# ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── 3.C — AI Chatbot (Google Gemini) ───────────────────────────────────────
# Gemini API key — https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=
# Model adı — opsiyonel, default `gemini-2.0-flash-exp`
GEMINI_MODEL=gemini-2.0-flash-exp

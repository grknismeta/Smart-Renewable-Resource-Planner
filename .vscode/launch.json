{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "frontend (Windows Debug)",
      "cwd": "frontend",
      "program": "lib/main.dart",
      "request": "launch",
      "type": "dart",
      "deviceId": "windows",
      // Sadece YAKALANMAMIŞ (gerçek) hataları durdur.
      // Paket-içi caught exception'lar (vector_map_tiles, vs.) artık
      // debugger'ı dondurmaz — uygulama akışı kesintisiz devam eder.
      "exceptionPausedMode": "Unhandled"
    },
    {
      "name": "frontend (Windows Profile)",
      "cwd": "frontend",
      "program": "lib/main.dart",
      "request": "launch",
      "type": "dart",
      "deviceId": "windows",
      "flutterMode": "profile",
      "exceptionPausedMode": "Unhandled"
    },
    {
      "name": "frontend (Windows Release)",
      "cwd": "frontend",
      "program": "lib/main.dart",
      "request": "launch",
      "type": "dart",
      "deviceId": "windows",
      "flutterMode": "release",
      "exceptionPausedMode": "Unhandled"
    }
  ]
}
